<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Assistive Commons Watch" }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-page:          oklch(0.97 0.012 76);
      --bg-white:         white;
      --border:           oklch(0.91 0.012 75);
      --border-subtle:    oklch(0.94 0.008 75);
      --border-faint:     oklch(0.97 0.006 75);
      --text-primary:     oklch(0.18 0.025 50);
      --text-secondary:   oklch(0.42 0.02 50);
      --text-muted:       oklch(0.56 0.015 50);
      --accent-green:     oklch(0.43 0.14 165);
      --accent-green-bg:  oklch(0.94 0.06 165);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Figtree', system-ui, sans-serif;
      font-size: 16px;
      line-height: 1.5;
      background: var(--bg-page);
      color: var(--text-secondary);
    }

    a { color: inherit; text-decoration: none; }

    /* Skip-to-main link — visible on focus only */
    .skip-link {
      position: absolute; top: -48px; left: 8px;
      background: var(--accent-green); color: white;
      padding: 8px 16px; border-radius: 0 0 6px 6px;
      font-size: 14px; font-weight: 600; z-index: 1000;
      transition: top 0.1s; text-decoration: none;
    }
    .skip-link:focus { top: 0; outline: 2px solid white; outline-offset: 2px; }

    /* Global focus indicator */
    a:focus-visible,
    button:focus-visible {
      outline: 2px solid var(--accent-green);
      outline-offset: 2px;
      border-radius: 4px;
    }

    /* ── Shared header ── */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg-white);
      border-bottom: 1px solid var(--border);
      height: 56px;
    }
    .site-header .container { height: 100%; display: flex; align-items: center; }
    .wordmark {
      font-size: 15px; font-weight: 800; letter-spacing: -0.03em;
      color: var(--text-primary); margin-right: auto; text-decoration: none;
    }
    .wordmark:hover { opacity: 0.8; }
    .site-nav { display: flex; align-items: center; gap: 4px; }
    .site-nav a {
      font-size: 13px; font-weight: 500; color: var(--text-secondary);
      padding: 0 12px; border-radius: 6px; transition: background 0.15s;
      min-height: 44px; display: inline-flex; align-items: center;
    }
    .site-nav a:hover { background: var(--bg-page); }
    .site-nav a[aria-current="page"] {
      background: var(--bg-page); color: var(--text-primary); font-weight: 600;
    }
    .site-nav .nav-cta {
      font-size: 13px; font-weight: 600; color: white;
      background: var(--accent-green); padding: 0 15px;
      border-radius: 7px; margin-left: 8px; transition: background 0.15s;
      min-height: 44px; display: inline-flex; align-items: center;
    }
    .site-nav .nav-cta:hover { background: oklch(0.36 0.14 165); color: white; }

    /* Hamburger toggle — hidden on desktop */
    .nav-toggle {
      display: none;
      align-items: center; justify-content: center;
      width: 44px; height: 44px; flex-shrink: 0;
      background: none; border: none; border-radius: 6px;
      cursor: pointer; color: var(--text-primary); font-size: 20px;
    }
    .nav-toggle:hover { background: var(--bg-page); }

    @media (max-width: 640px) {
      .nav-toggle { display: flex; }
      /* Nav links hidden by default on mobile; revealed via drawer */
      .site-nav a:not(.nav-cta) { display: none; }
      /* Drawer open state */
      .site-nav.nav-open {
        position: fixed; top: 56px; left: 0; right: 0; z-index: 99;
        flex-direction: column; gap: 2px;
        background: var(--bg-white); border-bottom: 1px solid var(--border);
        box-shadow: 0 4px 12px oklch(0 0 0 / 0.1);
        padding: 8px 16px 12px;
      }
      .site-nav.nav-open a:not(.nav-cta) {
        display: flex; width: 100%; padding: 10px 12px;
      }
      .site-nav.nav-open .nav-cta {
        width: 100%; justify-content: center; margin-left: 0; margin-top: 4px;
      }
    }

    /* ── Shared layout ── */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }
    @media (max-width: 640px) { .container { padding: 0 16px; } }

    /* ── Shared footer ── */
    .site-footer {
      background: var(--bg-white); border-top: 1px solid var(--border);
      padding: 20px 0;
    }
    .site-footer .container {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 12px;
    }
    .footer-left { font-size: 12px; color: var(--text-secondary); }
    .footer-left a { color: var(--accent-green); }
    .footer-links { display: flex; gap: 16px; }
    .footer-links a {
      font-size: 12px; color: var(--text-secondary);
      min-height: 44px; display: inline-flex; align-items: center;
      transition: color 0.15s;
    }
    .footer-links a:hover { color: var(--text-primary); }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <header class="site-header">
    <div class="container">
      <a href="/" class="wordmark">Assistive Commons Watch</a>
      <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="site-nav-menu" aria-label="Open navigation menu">☰</button>
      <nav class="site-nav" id="site-nav-menu" aria-label="Site navigation">
        <a href="/browse/?mode=contribute">Contribute</a>
        <a href="/browse/?mode=use">Find a Tool</a>
        <a href="/about"{% if page.url and '/about' in page.url %} aria-current="page"{% endif %}>About</a>
        <a href="https://github.com/hoseasiu/assistive-commons-watch/issues/new?template=submit_project.yml" class="nav-cta">Submit a project →</a>
      </nav>
    </div>
  </header>
  {{ content | safe }}
  <footer class="site-footer">
    <div class="container">
      <div class="footer-left">
        Assistive Commons Watch ·
        <a href="https://creativecommons.org/publicdomain/zero/1.0/">Data: CC0</a> ·
        <a href="/methodology/">Score methodology</a>
      </div>
      <nav class="footer-links" aria-label="Footer">
        <a href="https://github.com/hoseasiu/assistive-commons-watch">GitHub</a>
        <a href="/about">About</a>
        <a href="https://github.com/hoseasiu/assistive-commons-watch/issues/new?template=submit_project.yml">Submit a project</a>
      </nav>
    </div>
  </footer>
  <script>
    (function () {
      const toggle = document.getElementById('nav-toggle');
      const nav    = document.getElementById('site-nav-menu');
      if (!toggle || !nav) return;
      function openNav() {
        nav.classList.add('nav-open');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'Close navigation menu');
        toggle.textContent = '✕';
      }
      function closeNav() {
        nav.classList.remove('nav-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open navigation menu');
        toggle.textContent = '☰';
      }
      toggle.addEventListener('click', () => {
        nav.classList.contains('nav-open') ? closeNav() : openNav();
      });
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && nav.classList.contains('nav-open')) {
          closeNav();
          toggle.focus();
        }
      });
      document.addEventListener('click', e => {
        if (!e.target.closest('.site-header')) closeNav();
      });
    })();
  </script>
</body>
</html>
