<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Assistive Commons Watch" }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-page:          oklch(0.97 0.012 76);
      --bg-white:         white;
      --border:           oklch(0.91 0.012 75);
      --border-subtle:    oklch(0.94 0.008 75);
      --border-faint:     oklch(0.97 0.006 75);
      --text-primary:     oklch(0.18 0.025 50);
      --text-secondary:   oklch(0.42 0.02 50);
      --text-muted:       oklch(0.56 0.015 50);
      --accent-green:     oklch(0.43 0.14 165);
      --accent-green-bg:  oklch(0.94 0.06 165);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Figtree', system-ui, sans-serif;
      font-size: 16px;
      line-height: 1.5;
      background: var(--bg-page);
      color: var(--text-secondary);
    }

    a { color: inherit; text-decoration: none; }

    /* Skip-to-main link — visible on focus only */
    .skip-link {
      position: absolute; top: -48px; left: 8px;
      background: var(--accent-green); color: white;
      padding: 8px 16px; border-radius: 0 0 6px 6px;
      font-size: 14px; font-weight: 600; z-index: 1000;
      transition: top 0.1s; text-decoration: none;
    }
    .skip-link:focus { top: 0; outline: 2px solid white; outline-offset: 2px; }

    /* Global focus indicator */
    a:focus-visible,
    button:focus-visible {
      outline: 2px solid var(--accent-green);
      outline-offset: 2px;
      border-radius: 4px;
    }

    /* ── Shared header ── */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg-white);
      border-bottom: 1px solid var(--border);
      height: 56px;
    }
    .site-header .container { height: 100%; display: flex; align-items: center; }
    .wordmark {
      font-size: 15px; font-weight: 800; letter-spacing: -0.03em;
      color: var(--text-primary); margin-right: auto; text-decoration: none;
    }
    .wordmark:hover { opacity: 0.8; }
    .site-nav { display: flex; align-items: center; gap: 4px; }
    .site-nav a {
      font-size: 13px; font-weight: 500; color: var(--text-secondary);
      padding: 0 12px; border-radius: 6px; transition: background 0.15s;
      min-height: 44px; display: inline-flex; align-items: center;
    }
    .site-nav a:hover { background: var(--bg-page); }
    .site-nav a[aria-current="page"] {
      background: var(--bg-page); color: var(--text-primary); font-weight: 600;
    }
    .site-nav .nav-cta {
      font-size: 13px; font-weight: 600; color: white;
      background: var(--accent-green); padding: 0 15px;
      border-radius: 7px; margin-left: 8px; transition: background 0.15s;
      min-height: 44px; display: inline-flex; align-items: center;
    }
    .site-nav .nav-cta:hover { background: oklch(0.36 0.14 165); color: white; }
    @media (max-width: 640px) {
      .site-nav a:not(.nav-cta) { display: none; }
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <header class="site-header">
    <div class="container">
      <a href="/" class="wordmark">Assistive Commons Watch</a>
      <nav class="site-nav" aria-label="Site navigation">
        <a href="/browse/?mode=contribute">Contribute</a>
        <a href="/browse/?mode=use">Find a Tool</a>
        <a href="/about"{% if page.url and '/about' in page.url %} aria-current="page"{% endif %}>About</a>
        <a href="https://github.com/hoseasiu/assistive-commons-watch/issues/new?template=submit_project.yml" class="nav-cta">Submit a project →</a>
      </nav>
    </div>
  </header>
  {{ content | safe }}
</body>
</html>
