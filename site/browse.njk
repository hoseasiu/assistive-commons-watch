---
layout: base.njk
title: Browse Projects — Assistive Commons Watch
---
<style>
  /* ── Layout helpers ── */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

  /* ── Page hero ── */
  .page-hero {
    background: var(--bg-white); border-bottom: 1px solid var(--border);
    padding: 24px 0 0;
  }
  .page-hero .container { display: flex; flex-direction: column; gap: 0; }
  .page-hero-top { display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap; margin-bottom: 16px; }
  .page-title {
    font-size: 28px; font-weight: 800; letter-spacing: -0.03em;
    color: oklch(0.17 0.025 50);
  }
  .page-subtitle { font-size: 14px; color: var(--text-muted); }

  /* Mode switcher tabs */
  .mode-tabs {
    display: flex; gap: 0;
  }
  .mode-tab {
    font-family: inherit; font-size: 14px; font-weight: 500;
    padding: 10px 18px; background: none; border: none;
    color: oklch(0.50 0.02 50); cursor: pointer;
    border-bottom: 2px solid transparent; margin-bottom: -1px;
    transition: color 0.15s; letter-spacing: 0.01em;
    text-decoration: none; display: inline-block;
  }
  .mode-tab:hover { color: var(--text-primary); }
  .mode-tab[data-active] {
    color: oklch(0.38 0.14 165); font-weight: 700;
    border-bottom-color: oklch(0.43 0.14 165);
  }
  .mode-tab--use[data-active] {
    color: oklch(0.35 0.14 245);
    border-bottom-color: oklch(0.50 0.14 245);
  }

  /* ── Browse layout ── */
  .browse-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 24px;
    padding: 24px 0 64px;
    align-items: start;
  }

  /* ── Filter panel ── */
  .filter-panel {
    background: var(--bg-white); border-radius: 12px;
    border: 1px solid var(--border); position: sticky; top: 72px;
  }
  .filter-panel-header {
    padding: 14px 16px; border-bottom: 1px solid var(--border-subtle);
    display: flex; align-items: center; justify-content: space-between;
  }
  .filter-panel-title {
    font-size: 12px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--text-primary);
  }
  .filter-clear-btn {
    font-size: 11px; font-weight: 600; color: var(--accent-green);
    background: none; border: none; cursor: pointer; padding: 2px 4px;
    border-radius: 4px; display: none;
  }
  .filter-clear-btn:hover { background: var(--accent-green-bg); }
  .filter-clear-btn.visible { display: block; }

  .filter-section {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .filter-section:last-child { border-bottom: none; }
  .filter-section-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.07em;
    text-transform: uppercase; color: var(--text-muted);
    margin-bottom: 10px;
  }
  .filter-options { display: flex; flex-direction: column; gap: 6px; }
  .filter-option {
    display: flex; align-items: center; gap: 8px;
    cursor: pointer; padding: 2px 0;
  }
  .filter-option input[type="checkbox"] {
    width: 14px; height: 14px; accent-color: var(--accent-green);
    cursor: pointer; flex-shrink: 0; margin: 0;
  }
  .filter-option input[type="radio"] {
    width: 14px; height: 14px; accent-color: var(--accent-green);
    cursor: pointer; flex-shrink: 0; margin: 0;
  }
  .filter-option-label {
    font-size: 13px; color: var(--text-secondary);
    cursor: pointer; user-select: none;
  }
  .filter-option input:checked + .filter-option-label {
    color: var(--text-primary); font-weight: 600;
  }

  /* Use-mode hides the health-tier filter section (shown via JS) */
  .filter-section[data-mode-hide] { display: none; }

  /* ── Results area ── */
  .results-area { display: flex; flex-direction: column; gap: 12px; }

  .results-toolbar {
    display: flex; align-items: center; gap: 12px;
    background: var(--bg-white); border-radius: 10px;
    border: 1px solid var(--border); padding: 10px 16px;
    flex-wrap: wrap;
  }
  .results-count {
    font-size: 13px; font-weight: 600; color: var(--text-primary);
    margin-right: auto;
  }
  .results-count-muted { color: var(--text-muted); font-weight: 400; }
  .sort-label { font-size: 12px; color: var(--text-muted); white-space: nowrap; }
  .sort-select {
    font-size: 13px; font-weight: 500; color: var(--text-primary);
    background: var(--bg-page); border: 1px solid var(--border);
    border-radius: 6px; padding: 5px 8px; cursor: pointer;
    font-family: inherit;
  }
  .sort-select:focus { outline: 2px solid var(--accent-green); outline-offset: 1px; }

  /* ── Project cards (contribute mode) ── */
  .project-cards { display: flex; flex-direction: column; gap: 10px; }

  .project-card {
    background: var(--bg-white); border-radius: 10px;
    border: 1px solid var(--border);
    display: grid; grid-template-columns: 1fr auto;
    gap: 12px; padding: 16px 18px;
    transition: border-color 0.15s, box-shadow 0.15s;
    text-decoration: none; color: inherit;
  }
  .project-card:hover {
    border-color: oklch(0.75 0.06 165);
    box-shadow: 0 2px 8px oklch(0 0 0 / 0.05);
  }
  .project-card:focus-visible {
    outline: 2px solid var(--accent-green); outline-offset: 2px;
  }

  .card-main { min-width: 0; }
  .card-name {
    font-size: 15px; font-weight: 700; color: oklch(0.17 0.025 50);
    margin-bottom: 4px; letter-spacing: -0.01em;
  }
  .card-desc {
    font-size: 13px; line-height: 1.55; color: var(--text-muted);
    margin-bottom: 10px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tags { display: flex; flex-wrap: wrap; gap: 5px; align-items: center; }
  .card-tag {
    display: inline-block; padding: 2px 8px; border-radius: 100px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.02em;
    background: var(--bg-page); border: 1px solid var(--border);
    color: var(--text-secondary);
  }
  .card-tag--area {
    background: oklch(0.93 0.06 165); border-color: oklch(0.80 0.10 165);
    color: oklch(0.30 0.12 165);
  }
  .card-meta {
    font-size: 11px; color: var(--text-muted); margin-left: auto; margin-top: 2px;
    white-space: nowrap;
  }
  .card-right {
    display: flex; flex-direction: column; align-items: flex-end;
    gap: 8px; flex-shrink: 0;
  }
  .tier-pill {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 100px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .tier-pill-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .card-score {
    font-size: 20px; font-weight: 800; letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums; color: var(--text-primary);
    text-align: right;
  }
  .card-score-label {
    font-size: 10px; color: var(--text-muted); text-align: right;
    font-weight: 500; letter-spacing: 0.03em; margin-top: -2px;
  }

  /* ── Use-mode card overrides ── */
  .project-card--use:hover {
    border-color: oklch(0.75 0.07 245);
  }
  .card-use-badges { display: flex; flex-wrap: wrap; gap: 5px; align-items: center; margin-top: 8px; }

  .use-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 9px; border-radius: 100px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .use-badge--beginner  { background: oklch(0.93 0.08 142); color: oklch(0.28 0.14 142); border: 1px solid oklch(0.80 0.12 142); }
  .use-badge--maker     { background: oklch(0.96 0.06 84);  color: oklch(0.38 0.12 84);  border: 1px solid oklch(0.84 0.10 84); }
  .use-badge--engineer  { background: oklch(0.96 0.07 47);  color: oklch(0.38 0.14 47);  border: 1px solid oklch(0.84 0.12 47); }
  .use-badge--cost      { background: var(--bg-page); color: var(--text-secondary); border: 1px solid var(--border); }
  .use-badge--docs      { background: oklch(0.94 0.06 245); color: oklch(0.30 0.12 245); border: 1px solid oklch(0.80 0.10 245); }
  .use-badge--feedback  { background: oklch(0.95 0.04 165); color: oklch(0.32 0.10 165); border: 1px solid oklch(0.82 0.08 165); }
  .use-badge--download  { background: oklch(0.93 0.09 142); color: oklch(0.28 0.14 142); border: 1px solid oklch(0.78 0.13 142); text-decoration: none; }
  .use-badge--download:hover { background: oklch(0.88 0.11 142); }
  .card-tag--platform   { background: oklch(0.95 0.04 255); border-color: oklch(0.82 0.07 255); color: oklch(0.34 0.10 255); }

  .card-maintenance {
    font-size: 12px; font-weight: 700; letter-spacing: 0.01em;
    white-space: nowrap; text-align: right;
  }
  .card-maintenance-label {
    font-size: 10px; color: var(--text-muted); text-align: right;
    font-weight: 500; margin-top: 2px;
  }

  /* ── Search bar ── */
  .search-bar {
    display: flex; align-items: center; gap: 10px;
    background: var(--bg-white); border-radius: 10px;
    border: 1px solid var(--border); padding: 10px 14px;
  }
  .search-bar:focus-within {
    border-color: var(--accent-green);
    box-shadow: 0 0 0 2px oklch(0.43 0.14 165 / 0.12);
  }
  .search-icon {
    flex-shrink: 0; width: 16px; height: 16px;
    color: var(--text-muted);
  }
  .search-input {
    flex: 1; border: none; outline: none; background: none;
    font-family: inherit; font-size: 14px; color: var(--text-primary);
    min-width: 0;
  }
  .search-input::placeholder { color: var(--text-muted); }
  .search-clear-btn {
    flex-shrink: 0; background: none; border: none; cursor: pointer;
    padding: 2px 4px; border-radius: 4px; font-size: 14px;
    color: var(--text-muted); display: none; line-height: 1;
  }
  .search-clear-btn:hover { background: var(--bg-page); color: var(--text-primary); }
  .search-clear-btn.visible { display: block; }

  /* ── Empty state ── */
  .empty-state {
    text-align: center; padding: 56px 24px;
    background: var(--bg-white); border-radius: 10px;
    border: 1px solid var(--border);
  }
  .empty-state-icon { font-size: 32px; margin-bottom: 12px; }
  .empty-state-title { font-size: 16px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
  .empty-state-body { font-size: 14px; color: var(--text-muted); }
  .empty-clear-link {
    display: inline-block; margin-top: 14px; font-size: 13px;
    font-weight: 600; color: var(--accent-green); cursor: pointer;
    background: none; border: none; font-family: inherit;
  }
  .empty-clear-link:hover { text-decoration: underline; }

  /* ── No-JS fallback ── */
  .no-js-note { font-size: 12px; color: var(--text-muted); padding: 6px 0; }

  /* ── Mobile filter toggle ── */
  .filter-toggle-btn {
    display: none; width: 100%; padding: 12px 16px;
    font-size: 14px; font-weight: 600;
    color: var(--text-primary); background: var(--bg-white);
    border: 1px solid var(--border); border-radius: 10px;
    cursor: pointer; text-align: left;
    margin-bottom: 12px;
  }
  .filter-toggle-btn:hover { background: var(--bg-page); }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .container { padding: 0 16px; }
    .site-nav a:not(.nav-cta) { display: none; }
    .browse-layout { grid-template-columns: 1fr; }
    .filter-toggle-btn { display: block; }
    .filter-panel { position: static; display: none; margin-bottom: 12px; }
    .filter-panel.open { display: block; }
    .mode-tab { padding: 10px 12px; font-size: 13px; }
  }
</style>

{# Embed all project data for client-side filtering #}
<script id="acw-data" type="application/json">
{{ acw.projects | dump | safe }}
</script>

<!-- ─────────────────────────── PAGE HERO ─────────────────────────── -->
<div class="page-hero">
  <div class="container">
    <div class="page-hero-top">
      <h1 class="page-title" id="page-title">Browse Projects</h1>
      <p class="page-subtitle" id="page-subtitle">{{ acw.projects | length }} open-source assistive technology projects</p>
    </div>
    <div class="mode-tabs" role="tablist" aria-label="Browse mode">
      <button class="mode-tab mode-tab--contribute" role="tab" data-mode-btn="contribute" aria-selected="false">
        For Contributors
      </button>
      <button class="mode-tab mode-tab--use" role="tab" data-mode-btn="use" aria-selected="false">
        Find a Tool
      </button>
    </div>
  </div>
</div>

<!-- ─────────────────────────── MAIN ─────────────────────────── -->
<main>
  <div class="container">
    <div class="browse-layout">

      <!-- ── Filter panel ── -->
      <aside aria-label="Filter projects">
        <button class="filter-toggle-btn" id="filter-toggle-btn" aria-expanded="false" aria-controls="filter-panel">
          Filter projects ▾
        </button>
        <div class="filter-panel" id="filter-panel">
          <div class="filter-panel-header">
            <span class="filter-panel-title">Filter</span>
            <button class="filter-clear-btn" id="clear-all-btn" aria-label="Clear all filters">Clear all</button>
          </div>

          <!-- Disability area -->
          <div class="filter-section">
            <div class="filter-section-label" id="area-label">Disability Area</div>
            <div class="filter-options" role="group" aria-labelledby="area-label">
              <label class="filter-option">
                <input type="checkbox" name="area" value="eyegaze">
                <span class="filter-option-label">Eye Gaze / Tracking</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="area" value="motor">
                <span class="filter-option-label">Motor / Switch Access</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="area" value="communication">
                <span class="filter-option-label">AAC / Communication</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="area" value="vision">
                <span class="filter-option-label">Vision / Braille</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="area" value="cognitive">
                <span class="filter-option-label">Cognitive</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="area" value="hearing">
                <span class="filter-option-label">Hearing</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="area" value="prosthetics">
                <span class="filter-option-label">Prosthetics / Rehab</span>
              </label>
            </div>
          </div>

          <!-- Health tier (contribute mode) / Maintenance (use mode handled via default filter) -->
          <div class="filter-section" id="tier-filter-section">
            <div class="filter-section-label" id="tier-label">Health Tier</div>
            <div class="filter-options" role="group" aria-labelledby="tier-label">
              <label class="filter-option">
                <input type="checkbox" name="tier" value="thriving">
                <span class="filter-option-label">Thriving</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="tier" value="stable">
                <span class="filter-option-label">Stable</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="tier" value="dormant">
                <span class="filter-option-label">Dormant</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="tier" value="at_risk">
                <span class="filter-option-label">At Risk</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="tier" value="archived">
                <span class="filter-option-label">Archived</span>
              </label>
            </div>
          </div>

          <!-- Modality -->
          <div class="filter-section">
            <div class="filter-section-label" id="modality-label">Type</div>
            <div class="filter-options" role="group" aria-labelledby="modality-label">
              <label class="filter-option">
                <input type="checkbox" name="modality" value="hardware">
                <span class="filter-option-label">Hardware</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="modality" value="software">
                <span class="filter-option-label">Software</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="modality" value="firmware">
                <span class="filter-option-label">Firmware</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="modality" value="hybrid">
                <span class="filter-option-label">Hardware + Software</span>
              </label>
            </div>
          </div>

          <!-- Skill level -->
          <div class="filter-section">
            <div class="filter-section-label" id="skill-label">Skill Level Required</div>
            <div class="filter-options" role="group" aria-labelledby="skill-label">
              <label class="filter-option">
                <input type="checkbox" name="skill" value="beginner">
                <span class="filter-option-label">Beginner-friendly</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="skill" value="maker">
                <span class="filter-option-label">Maker / DIY</span>
              </label>
              <label class="filter-option">
                <input type="checkbox" name="skill" value="engineer">
                <span class="filter-option-label">Engineer</span>
              </label>
            </div>
          </div>

          <!-- Co-design / NAUWU -->
          <div class="filter-section">
            <div class="filter-section-label" id="codesign-label">Co-designed (NAUWU)</div>
            <div class="filter-options" role="group" aria-labelledby="codesign-label">
              <label class="filter-option">
                <input type="radio" name="codesign" value="all" checked>
                <span class="filter-option-label">Any</span>
              </label>
              <label class="filter-option">
                <input type="radio" name="codesign" value="yes">
                <span class="filter-option-label">Yes — co-designed</span>
              </label>
              <label class="filter-option">
                <input type="radio" name="codesign" value="no">
                <span class="filter-option-label">No evidence</span>
              </label>
              <label class="filter-option">
                <input type="radio" name="codesign" value="unknown">
                <span class="filter-option-label">Unknown</span>
              </label>
            </div>
          </div>

        </div><!-- /filter-panel -->
      </aside>

      <!-- ── Results area ── -->
      <div class="results-area">

        <!-- Search bar -->
        <div class="search-bar">
          <svg class="search-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="6.5" cy="6.5" r="4.5"/>
            <line x1="10.5" y1="10.5" x2="14" y2="14"/>
          </svg>
          <input
            class="search-input"
            id="search-input"
            type="search"
            placeholder="Search projects by name or description…"
            aria-label="Search projects"
            autocomplete="off"
          >
          <button class="search-clear-btn" id="search-clear-btn" aria-label="Clear search">✕</button>
        </div>

        <!-- Toolbar -->
        <div class="results-toolbar" role="toolbar" aria-label="Sort and result count">
          <span class="results-count" id="results-count" aria-live="polite" aria-atomic="true">
            <span id="count-num">{{ acw.projects | length }}</span>
            <span class="results-count-muted"> projects</span>
          </span>
          <label class="sort-label" for="sort-select">Sort by</label>
          <select class="sort-select" id="sort-select" aria-label="Sort projects by">
            <option value="score-desc">Health score ↓</option>
            <option value="score-asc">Health score ↑</option>
            <option value="skill-asc">Beginner first</option>
            <option value="name-asc">Name A–Z</option>
            <option value="name-desc">Name Z–A</option>
            <option value="stars-desc">Stars ↓</option>
            <option value="commit-desc">Last commit ↓</option>
          </select>
        </div>

        <!-- Cards list -->
        <div class="project-cards" id="project-cards" role="list" aria-label="Project results">
          <noscript>
            <p class="no-js-note">Enable JavaScript to filter and sort projects.</p>
          </noscript>
          {%- for p in acw.projects | sort(attribute='health_score', reverse=true) -%}
          <a
            class="project-card"
            href="/projects/{{ p.id }}/"
            role="listitem"
            aria-label="{{ p.name }}, {{ p.health_tier_label }} — {{ p.description | truncate(120) }}"
            data-id="{{ p.id }}"
          >
            <div class="card-main">
              <div class="card-name">{{ p.name }}</div>
              <div class="card-desc">{{ p.description }}</div>
              <div class="card-tags">
                {%- for label in p.disability_area_labels -%}
                <span class="card-tag card-tag--area">{{ label }}</span>
                {%- endfor -%}
                <span class="card-tag">{{ p.modality_label }}</span>
                {%- if p.skill_level_label -%}
                <span class="card-tag">{{ p.skill_level_label }}</span>
                {%- endif -%}
                {%- if p.github_last_commit -%}
                <span class="card-meta">Last commit {{ p.github_last_commit }}</span>
                {%- endif -%}
              </div>
            </div>
            <div class="card-right">
              <span
                class="tier-pill"
                style="background: {{ p.health_tier | tierColor }}18; color: {{ p.health_tier | tierColor }}; border: 1px solid {{ p.health_tier | tierColor }}35;"
              >
                <span class="tier-pill-dot" style="background: {{ p.health_tier | tierColor }}" aria-hidden="true"></span>
                {{ p.health_tier_label }}
              </span>
              <div>
                <div class="card-score">{{ p.health_score }}</div>
                <div class="card-score-label">/ 10</div>
              </div>
            </div>
          </a>
          {%- endfor -%}
        </div>

        <!-- Empty state -->
        <div class="empty-state" id="empty-state" style="display:none;" role="status" aria-live="polite">
          <div class="empty-state-icon" aria-hidden="true">🔍</div>
          <div class="empty-state-title" id="empty-state-title">No projects match your filters</div>
          <p class="empty-state-body" id="empty-state-body">Try removing one or more filters to see more results.</p>
          <button class="empty-clear-link" id="empty-clear-btn">Clear all filters</button>
        </div>

      </div><!-- /results-area -->

    </div><!-- /browse-layout -->
  </div>
</main>


<script>
(function () {
  const PATH_PREFIX = ({{ env.pathPrefix | dump | safe }}).replace(/\/?$/, '/');
  const PROJECTS = JSON.parse(document.getElementById('acw-data').textContent);

  // ── Constants ────────────────────────────────────────────────────────────
  const TIER_COLORS = {
    thriving:   'oklch(0.52 0.16 142)',
    stable:     'oklch(0.50 0.14 245)',
    dormant:    'oklch(0.72 0.13 83)',
    at_risk:    'oklch(0.62 0.17 47)',
    archived:   'oklch(0.52 0.14 22)',
    unverified: 'oklch(0.80 0.02 250)',
  };
  const TIER_LABELS = {
    thriving: 'Thriving', stable: 'Stable', dormant: 'Dormant',
    at_risk: 'At Risk', archived: 'Archived', unverified: 'Unverified',
  };
  // Plain-language maintenance labels for use mode
  const MAINTENANCE_LABELS = {
    thriving:   { label: 'Actively developed', color: 'oklch(0.36 0.15 142)' },
    stable:     { label: 'Actively maintained', color: 'oklch(0.35 0.14 245)' },
    dormant:    { label: 'Dormant — still usable', color: 'oklch(0.50 0.12 83)' },
    at_risk:    { label: 'Needs attention', color: 'oklch(0.50 0.15 47)' },
    archived:   { label: 'Archived', color: 'oklch(0.48 0.08 22)' },
    unverified:  { label: 'Not yet assessed', color: 'oklch(0.55 0.02 50)' },
    documented:  { label: 'Community build project', color: 'oklch(0.40 0.10 290)' },
  };
  const SKILL_ORDER = { beginner: 0, maker: 1, engineer: 2 };
  const USE_MODE_DEFAULT_TIERS = ['thriving', 'stable', 'dormant', 'documented'];

  // ── DOM refs ─────────────────────────────────────────────────────────────
  const cardsContainer  = document.getElementById('project-cards');
  const emptyState      = document.getElementById('empty-state');
  const countNum        = document.getElementById('count-num');
  const sortSelect      = document.getElementById('sort-select');
  const clearAllBtn     = document.getElementById('clear-all-btn');
  const emptyClearBtn   = document.getElementById('empty-clear-btn');
  const pageTitle       = document.getElementById('page-title');
  const pageSubtitle    = document.getElementById('page-subtitle');
  const tierFilterSection = document.getElementById('tier-filter-section');
  const modeBtns        = document.querySelectorAll('[data-mode-btn]');
  const searchInput     = document.getElementById('search-input');
  const searchClearBtn  = document.getElementById('search-clear-btn');

  // Remove static server-rendered cards (JS takes over rendering)
  cardsContainer.innerHTML = '';

  // ── Mode ─────────────────────────────────────────────────────────────────
  function getMode() {
    return new URLSearchParams(location.search).get('mode') || 'contribute';
  }

  function applyModeUI(mode) {
    modeBtns.forEach(btn => {
      const isActive = btn.dataset.modeBtn === mode;
      if (isActive) btn.setAttribute('data-active', '');
      else btn.removeAttribute('data-active');
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    if (mode === 'use') {
      pageTitle.textContent = 'Find a Tool';
      pageSubtitle.textContent = 'Showing primary AT — tools directly usable by disabled people';
      tierFilterSection.style.display = 'none';
      // Default sort to beginner-first in use mode if not set
      const p = new URLSearchParams(location.search);
      if (!p.get('sort')) sortSelect.value = 'skill-asc';
    } else {
      pageTitle.textContent = 'For Contributors';
      pageSubtitle.textContent = PROJECTS.length + ' open-source assistive technology projects';
      tierFilterSection.style.display = '';
      const p = new URLSearchParams(location.search);
      if (!p.get('sort')) sortSelect.value = 'score-desc';
    }
  }

  // ── Read/write URL state ─────────────────────────────────────────────────
  function getFilters() {
    const p = new URLSearchParams(location.search);
    const mode = p.get('mode') || 'contribute';
    const defaultSort = mode === 'use' ? 'skill-asc' : 'score-desc';
    return {
      mode,
      area:     p.get('area')     ? p.get('area').split(',').filter(Boolean)     : [],
      tier:     p.get('tier')     ? p.get('tier').split(',').filter(Boolean)     : [],
      modality: p.get('modality') ? p.get('modality').split(',').filter(Boolean) : [],
      skill:    p.get('skill')    ? p.get('skill').split(',').filter(Boolean)    : [],
      codesign: p.get('codesign') || 'all',
      sort:     p.get('sort')     || defaultSort,
      query:    searchInput.value.trim() || p.get('q') || '',
    };
  }

  function applyFiltersToUI(filters) {
    document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
      cb.checked = filters[cb.name] && filters[cb.name].includes(cb.value);
    });
    document.querySelectorAll('input[type="radio"]').forEach(r => {
      r.checked = r.value === filters.codesign;
    });
    sortSelect.value = filters.sort;
    if (searchInput.value.trim() !== filters.query) searchInput.value = filters.query || '';
  }

  function pushState(filters) {
    const p = new URLSearchParams();
    if (filters.mode && filters.mode !== 'contribute') p.set('mode', filters.mode);
    if (filters.area.length)     p.set('area', filters.area.join(','));
    if (filters.tier.length)     p.set('tier', filters.tier.join(','));
    if (filters.modality.length) p.set('modality', filters.modality.join(','));
    if (filters.skill.length)    p.set('skill', filters.skill.join(','));
    if (filters.codesign !== 'all') p.set('codesign', filters.codesign);
    if (filters.query) p.set('q', filters.query);
    const defaultSort = filters.mode === 'use' ? 'skill-asc' : 'score-desc';
    if (filters.sort !== defaultSort) p.set('sort', filters.sort);
    const qs = p.toString();
    history.replaceState(null, '', qs ? '?' + qs : location.pathname);
  }

  // ── Filter + sort logic ──────────────────────────────────────────────────
  function applyCodesignFilter(project, value) {
    if (value === 'all') return true;
    const v = project.nothing_about_us;
    if (value === 'yes')     return v === true;
    if (value === 'no')      return v === false;
    if (value === 'unknown') return v === null || v === undefined;
    return true;
  }

  function filterAndSort(filters) {
    let activeTiers = filters.tier;

    // In use mode with no explicit tier filter, apply the default set
    if (filters.mode === 'use' && activeTiers.length === 0) {
      activeTiers = USE_MODE_DEFAULT_TIERS;
    }

    const queryLower = filters.query ? filters.query.toLowerCase() : '';

    let results = PROJECTS.filter(p => {
      // In use mode, only show primary AT (directly usable by disabled people)
      if (filters.mode === 'use' && p.at_relevance !== 'primary') return false;
      if (queryLower) {
        const searchable = [p.name, p.description, p.plain_language_description]
          .filter(Boolean).join(' ').toLowerCase();
        if (!searchable.includes(queryLower)) return false;
      }
      if (filters.area.length && !filters.area.some(a => (p.disability_area || []).includes(a)))
        return false;
      if (activeTiers.length && !activeTiers.includes(p.health_tier))
        return false;
      if (filters.modality.length && !filters.modality.includes(p.modality))
        return false;
      if (filters.skill.length && !filters.skill.includes(p.skill_level))
        return false;
      if (!applyCodesignFilter(p, filters.codesign))
        return false;
      return true;
    });

    results.sort((a, b) => {
      switch (filters.sort) {
        case 'skill-asc': {
          const ao = SKILL_ORDER[a.skill_level] ?? 99;
          const bo = SKILL_ORDER[b.skill_level] ?? 99;
          return ao !== bo ? ao - bo : a.name.localeCompare(b.name);
        }
        case 'score-asc':  return (a.health_score ?? 0) - (b.health_score ?? 0);
        case 'name-asc':   return a.name.localeCompare(b.name);
        case 'name-desc':  return b.name.localeCompare(a.name);
        case 'stars-desc': return (b.github_stars ?? -1) - (a.github_stars ?? -1);
        case 'commit-desc':
          return (b.github_last_commit || '').localeCompare(a.github_last_commit || '');
        default: // score-desc
          return (b.health_score ?? 0) - (a.health_score ?? 0);
      }
    });
    return results;
  }

  // ── Card rendering ────────────────────────────────────────────────────────
  function hasActiveFilters(filters) {
    return filters.area.length || filters.tier.length || filters.modality.length ||
           filters.skill.length || filters.codesign !== 'all' || filters.query;
  }

  function truncate(str, max) {
    if (!str || str.length <= max) return str || '';
    return str.slice(0, max).trimEnd() + '…';
  }

  function renderContributeCard(p) {
    const color = TIER_COLORS[p.health_tier] || TIER_COLORS.unverified;
    const label = TIER_LABELS[p.health_tier]  || p.health_tier;
    const areaTagsHtml = (p.disability_area_labels || [])
      .map(l => `<span class="card-tag card-tag--area">${l}</span>`).join('');
    const modalityHtml = p.modality_label
      ? `<span class="card-tag">${p.modality_label}</span>` : '';
    const skillHtml = p.skill_level_label
      ? `<span class="card-tag">${p.skill_level_label}</span>` : '';
    const commitHtml = p.github_last_commit
      ? `<span class="card-meta">Last commit ${p.github_last_commit}</span>` : '';

    const a = document.createElement('a');
    a.className = 'project-card';
    a.href = `${PATH_PREFIX}projects/${p.id}/`;
    a.setAttribute('role', 'listitem');
    a.setAttribute('aria-label', `${p.name}, ${label} — ${truncate(p.description, 120)}`);
    a.dataset.id = p.id;
    a.innerHTML = `
      <div class="card-main">
        <div class="card-name">${p.name}</div>
        <div class="card-desc">${p.description || ''}</div>
        <div class="card-tags">
          ${areaTagsHtml}${modalityHtml}${skillHtml}${commitHtml}
        </div>
      </div>
      <div class="card-right">
        <span class="tier-pill"
          style="background:${color}18;color:${color};border:1px solid ${color}35;">
          <span class="tier-pill-dot" style="background:${color}" aria-hidden="true"></span>
          ${label}
        </span>
        <div>
          <div class="card-score">${p.health_score ?? '—'}</div>
          <div class="card-score-label">/ 10</div>
        </div>
      </div>`;
    return a;
  }

  function renderUseCard(p) {
    const maintenance = MAINTENANCE_LABELS[p.health_tier] || MAINTENANCE_LABELS.unverified;
    const areaTagsHtml = (p.disability_area_labels || [])
      .map(l => `<span class="card-tag card-tag--area">${l}</span>`).join('');
    const modalityHtml = p.modality_label
      ? `<span class="card-tag">${p.modality_label}</span>` : '';

    // Skill badge
    let skillBadge = '';
    if (p.skill_level === 'beginner') {
      skillBadge = `<span class="use-badge use-badge--beginner">Beginner-friendly</span>`;
    } else if (p.skill_level === 'maker') {
      skillBadge = `<span class="use-badge use-badge--maker">Requires DIY / assembly</span>`;
    } else if (p.skill_level === 'engineer') {
      skillBadge = `<span class="use-badge use-badge--engineer">Technical setup required</span>`;
    }

    // Cost badge
    let costBadge = '';
    if (p.cost_range) {
      costBadge = `<span class="use-badge use-badge--cost">${p.cost_range}</span>`;
    } else if (p.modality === 'software') {
      costBadge = `<span class="use-badge use-badge--cost">Free</span>`;
    }

    // User docs + feedback badges
    const docsBadge = p.end_user_docs
      ? `<span class="use-badge use-badge--docs">User docs ✓</span>` : '';
    const feedbackBadge = p.feedback_channel
      ? `<span class="use-badge use-badge--feedback">Feedback channel ✓</span>` : '';

    // Download badge
    const downloadBadge = p.download_ready && p.latest_release_url
      ? `<a class="use-badge use-badge--download" href="${p.latest_release_url}" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">Download available ↗</a>` : '';

    // Platform badges
    const PLATFORM_LABELS = {
      windows: 'Windows', linux: 'Linux', macos: 'macOS',
      web: 'Web', ios: 'iOS', android: 'Android', 'hardware-only': 'Hardware'
    };
    const platformTagsHtml = (p.platform || [])
      .map(pl => `<span class="card-tag card-tag--platform">${PLATFORM_LABELS[pl] || pl}</span>`).join('');

    const desc = p.plain_language_description || p.description || '';

    const a = document.createElement('a');
    a.className = 'project-card project-card--use';
    a.href = `${PATH_PREFIX}projects/${p.id}/`;
    a.setAttribute('role', 'listitem');
    a.setAttribute('aria-label', `${p.name}, ${maintenance.label} — ${truncate(desc, 120)}`);
    a.dataset.id = p.id;
    a.innerHTML = `
      <div class="card-main">
        <div class="card-name">${p.name}</div>
        <div class="card-desc">${desc}</div>
        <div class="card-tags">${areaTagsHtml}${modalityHtml}${platformTagsHtml}</div>
        <div class="card-use-badges">
          ${skillBadge}${costBadge}${docsBadge}${feedbackBadge}${downloadBadge}
        </div>
      </div>
      <div class="card-right">
        <div class="card-maintenance" style="color:${maintenance.color}">${maintenance.label}</div>
      </div>`;
    return a;
  }

  // ── Render ────────────────────────────────────────────────────────────────
  function render() {
    const filters = getFilters();
    const results = filterAndSort(filters);

    applyModeUI(filters.mode);
    applyFiltersToUI(filters);

    const active = hasActiveFilters(filters);
    clearAllBtn.classList.toggle('visible', active);
    searchClearBtn.classList.toggle('visible', !!filters.query);
    countNum.textContent = results.length;

    cardsContainer.innerHTML = '';
    if (results.length === 0) {
      const emptyTitle = document.getElementById('empty-state-title');
      const emptyBody  = document.getElementById('empty-state-body');
      if (filters.query && !hasActiveFilters({ ...filters, query: '' })) {
        emptyTitle.textContent = `No projects found for "${filters.query}"`;
        emptyBody.textContent  = 'Try a different search term or browse all projects.';
      } else {
        emptyTitle.textContent = 'No projects match your filters';
        emptyBody.textContent  = 'Try removing one or more filters to see more results.';
      }
      emptyState.style.display = '';
    } else {
      emptyState.style.display = 'none';
      const frag = document.createDocumentFragment();
      const renderCard = filters.mode === 'use' ? renderUseCard : renderContributeCard;
      results.forEach(p => frag.appendChild(renderCard(p)));
      cardsContainer.appendChild(frag);
    }
  }

  // ── Event handlers ────────────────────────────────────────────────────────
  function readCurrentFilters() {
    const area = [...document.querySelectorAll('input[name="area"]:checked')].map(i => i.value);
    const tier = [...document.querySelectorAll('input[name="tier"]:checked')].map(i => i.value);
    const modality = [...document.querySelectorAll('input[name="modality"]:checked')].map(i => i.value);
    const skill = [...document.querySelectorAll('input[name="skill"]:checked')].map(i => i.value);
    const codesignEl = document.querySelector('input[name="codesign"]:checked');
    const codesign = codesignEl ? codesignEl.value : 'all';
    const sort = sortSelect.value;
    const mode = getMode();
    const query = searchInput.value.trim();
    return { mode, area, tier, modality, skill, codesign, sort, query };
  }

  function onFilterChange() {
    const filters = readCurrentFilters();
    pushState(filters);
    render();
  }

  function clearAllFilters() {
    document.querySelectorAll('input[type="checkbox"]').forEach(cb => { cb.checked = false; });
    const allRadio = document.querySelector('input[name="codesign"][value="all"]');
    if (allRadio) allRadio.checked = true;
    searchInput.value = '';
    const mode = getMode();
    sortSelect.value = mode === 'use' ? 'skill-asc' : 'score-desc';
    const p = new URLSearchParams();
    if (mode !== 'contribute') p.set('mode', mode);
    history.replaceState(null, '', p.toString() ? '?' + p.toString() : location.pathname);
    render();
  }

  // Mode tab switching
  modeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const newMode = btn.dataset.modeBtn;
      // Switch mode, reset to mode defaults
      const p = new URLSearchParams();
      if (newMode !== 'contribute') p.set('mode', newMode);
      if (newMode === 'use') p.set('tier', USE_MODE_DEFAULT_TIERS.join(','));
      history.replaceState(null, '', '?' + p.toString());
      // Reset filter UI
      document.querySelectorAll('input[type="checkbox"]').forEach(cb => { cb.checked = false; });
      const allRadio = document.querySelector('input[name="codesign"][value="all"]');
      if (allRadio) allRadio.checked = true;
      searchInput.value = '';
      render();
    });
  });

  document.querySelectorAll('input[type="checkbox"], input[type="radio"]')
    .forEach(el => el.addEventListener('change', onFilterChange));
  sortSelect.addEventListener('change', onFilterChange);
  clearAllBtn.addEventListener('click', clearAllFilters);
  emptyClearBtn.addEventListener('click', clearAllFilters);
  searchInput.addEventListener('input', onFilterChange);
  searchClearBtn.addEventListener('click', () => {
    searchInput.value = '';
    onFilterChange();
    searchInput.focus();
  });
  window.addEventListener('popstate', render);

  // Mobile filter toggle
  const filterToggleBtn = document.getElementById('filter-toggle-btn');
  const filterPanelEl   = document.getElementById('filter-panel');
  if (filterToggleBtn && filterPanelEl) {
    filterToggleBtn.addEventListener('click', () => {
      const open = filterPanelEl.classList.toggle('open');
      filterToggleBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      filterToggleBtn.textContent = open ? 'Filter projects ▴' : 'Filter projects ▾';
    });
  }

  render();
})();
</script>
